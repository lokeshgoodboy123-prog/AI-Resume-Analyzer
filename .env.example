# MongoDB connection string
# Get a free cluster at https://www.mongodb.com/atlas/database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/resume-analyzer

# OpenAI API key
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# JWT secret — use a long random string (at least 32 characters)
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server port (set automatically by Replit)
PORT=8080
